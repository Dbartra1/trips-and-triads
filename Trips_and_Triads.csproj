<Project Sdk="Godot.NET.Sdk/4.6.3">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <!-- Exclude the xUnit test suite from Godot's build.
         It has its own project file and is built separately via dotnet CLI,
         referencing this project directly (see Tests/TripsAndTriads.Tests.csproj). -->
    <Compile Remove="Tests/**" />
  </ItemGroup>
</Project>