<Project Sdk="Godot.NET.Sdk/4.6.3">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <!-- Exclude the standalone Logic library and xUnit test suite from Godot's build.
         These have their own project files and are built separately via dotnet CLI. -->
    <Compile Remove="Logic/**" />
    <Compile Remove="Tests/**" />
  </ItemGroup>
</Project>